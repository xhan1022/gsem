# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-chat

# Embedding API Configuration (for Stage 5 similarity matching)
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# Pipeline Configuration
MAX_WORKERS=5
TEMPERATURE=0.8
SAMPLING_COUNT=5

# Dataset Configuration
TRAIN_DATASET_PATH=data/backup/MedRbench.json      # 726 cases (train set)
TEST_DATASET_PATH=data/backup/MedRbench_test.json  # 727 cases (test set)
DATASET_SPLIT=train  # 'train' or 'test'

# ERV (Experience Replay Validation) Configuration
